{
  "name": "secureflow",
  "version": "2.0.0",
  "private": true,
  "description": "Fraud detection for UPI transactions via ML, Redis, and a custom blockchain audit trail.",
  "scripts": {
    "frontend:dev": "npm --prefix frontend run dev",
    "frontend:build": "npm --prefix frontend run build",
    "frontend:install": "npm --prefix frontend install",
    "backend:dev": "cd backend && uvicorn app.main:app --reload --port 8000",
    "backend:train": "cd backend && python -m app.ml.training",
    "backend:test": "cd backend && pytest -q"
  },
  "license": "MIT"
}
