# ── Application ──────────────────────────────────────────────────────────────
APP_NAME=SecureFlow
ENVIRONMENT=development          # development | production
LOG_LEVEL=INFO
API_PORT=8000

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:3000,https://secure-flow-inky.vercel.app

# ── Database ─────────────────────────────────────────────────────────────────
# Local dev defaults to SQLite if unset. In production use a PostgreSQL URL, e.g.
# DATABASE_URL=postgresql+psycopg2://user:password@host:5432/secureflow
DATABASE_URL=sqlite:///./data/secureflow.db

# ── Redis ────────────────────────────────────────────────────────────────────
# If unset or unreachable, the app degrades gracefully (skips caching / pub-sub).
REDIS_URL=redis://localhost:6379/0

# ── Security / JWT ───────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=change_me_in_production_use_a_long_random_secret
JWT_REFRESH_SECRET=change_me_too_a_different_long_random_secret
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ML ───────────────────────────────────────────────────────────────────────
MODEL_PATH=./data/fraud_model.joblib
MODEL_METRICS_PATH=./data/model_metrics.json

# ── Blockchain ───────────────────────────────────────────────────────────────
BLOCKCHAIN_PATH=./data/chain.json
BLOCKCHAIN_DIFFICULTY=2

# ── Rate limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=60          # max requests per window per IP per endpoint
RATE_LIMIT_WINDOW_SECONDS=60
